#!/usr/bin/env bash
# Performance-tuning profile.
# Keep the same conservative defaults unless you are actively benchmarking
# a specific change. This file is intentionally explicit so it can be audited
# and edited without touching launcher logic.

export WINEMSYNC=1
export WINEESYNC=1
export DXVK_ASYNC=0
export MTL_HUD_ENABLED=0
export WINEDEBUG=-all
