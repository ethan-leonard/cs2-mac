# CS2-Mac canonical paths
CS2_MAC_ROOT="$HOME/Library/Application Support/CS2-Mac"
CS2_MAC_PREFIX="$CS2_MAC_ROOT/prefix"
CS2_MAC_LOGS="$CS2_MAC_ROOT/logs"
CS2_MAC_CACHE="$CS2_MAC_ROOT/cache"
CS2_MAC_RUNTIME_BIN="$CS2_MAC_ROOT/runtime/bin"

# Existing CrossOver Steam bottle (source migration path)
CROSSOVER_STEAM_BOTTLE="$HOME/Library/Application Support/CrossOver/Bottles/Steam"

# Steam paths inside target prefix
STEAM_ROOT_REL="drive_c/Program Files (x86)/Steam"
STEAM_EXE_REL="$STEAM_ROOT_REL/steam.exe"
STEAMAPPS_REL="$STEAM_ROOT_REL/steamapps"
STEAM_CONFIG_REL="$STEAM_ROOT_REL/config"
STEAM_USERDATA_REL="$STEAM_ROOT_REL/userdata"

# Default app id
CS2_APPID="730"
