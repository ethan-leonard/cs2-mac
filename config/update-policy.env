# Update-guard policy defaults.
# The launcher sources this file before each game launch.

# 1 = enforce guard checks from launch-cs2.sh
CS2_UPDATE_GUARD_ENFORCE=1

# 1 = block launch whenever Steam/CS2/runtime versions differ from approved baseline
CS2_UPDATE_GUARD_BLOCK_ON_ANY_UPDATE=1

# 1 = show a macOS popup dialog when launch is blocked
CS2_UPDATE_GUARD_SHOW_POPUP=1

# 1 = run quick non-match checks when an update delta is detected
CS2_UPDATE_GUARD_RUN_QUICK_CHECKS=1

# 1 = require conservative safe-profile settings to reduce VAC-risky drift
CS2_UPDATE_GUARD_REQUIRE_SAFE_PROFILE=1
